# -----------------------------------------------------------------------------
# Editor / agent local state
# -----------------------------------------------------------------------------
.cursor/

# -----------------------------------------------------------------------------
# Runtime logs and screen recordings (never commit)
# -----------------------------------------------------------------------------
*.log
*.mp4
*.mov
*.avi

# Policy weight backups (never commit)
policies/*.bak*

# -----------------------------------------------------------------------------
# colcon / ROS 2 build artifacts
# -----------------------------------------------------------------------------
build/
install/
log/
*.pyc
__pycache__/
.pytest_cache/

# -----------------------------------------------------------------------------
# ML model weights — these are large binary blobs that auto-download from
# the Ultralytics CDN on first run. Pinning them in git would balloon the
# repo to >800 MB and the hash mismatch on different platforms causes more
# pain than it solves. Operators install via README pre-flight steps.
# -----------------------------------------------------------------------------
*.pt
*.pth
*.onnx
# YOLOE pulls a 572 MB MobileCLIP TorchScript backbone on first launch
# (mobileclip_blt.ts). Same logic applies — never commit.
*.ts
# Some torch utilities cache backbones in the workspace root (yoloe-11s-seg.pt,
# yolo11l-seg.pt, mobileclip_blt.ts). Keep them out by name too as a belt-and-
# braces against the *.pt / *.ts globs being overridden in a subdir gitignore.
mobileclip_blt.ts
yolo*.pt
yoloe*.pt

# -----------------------------------------------------------------------------
# rosbag2 recordings — far too large for git (hundreds of GB on long runs).
# Keep them in the working tree for analysis but never push. The folder
# convention `rosbag2_<timestamp>/` is what `ros2 bag record` produces.
# -----------------------------------------------------------------------------
rosbag2_*/
*.mcap
*.bag
*.db3
# Project-specific ad-hoc bag folders.
bag_*/

# -----------------------------------------------------------------------------
# tf2_tools view_frames artifacts (generated in the CWD where they ran).
# -----------------------------------------------------------------------------
frames_*.pdf
frames_*.gv

# -----------------------------------------------------------------------------
# Day 3 — saved SLAM maps (binary, large). Keep the maps/ directory but
# the .pgm/.yaml/.png files inside are reproducible from
# `mapping.launch.py` + `save_map.sh`, so they don't need to be in git.
# -----------------------------------------------------------------------------
maps/*.pgm
maps/*.yaml
maps/*.png
!maps/.gitkeep

# -----------------------------------------------------------------------------
# Debug captures (TF tree dumps, screenshots, ad-hoc Python repros).
# Useful while iterating, never useful in git history.
# -----------------------------------------------------------------------------
debug/

# -----------------------------------------------------------------------------
# Sim runtime stdout captures (`script -q -f -c ... logs/sim_*.log`). These
# are session-local diagnostics for shader compile / Kit boot timing — useful
# in the moment, ~1 MB+ each, never useful in git history.
# -----------------------------------------------------------------------------
logs/

# -----------------------------------------------------------------------------
# Isaac Sim auto-generated USD thumbnail cache (sim/worlds/.thumbs/).
# These are regenerated by the Sim Stage browser on first open.
# -----------------------------------------------------------------------------
**/.thumbs/

# -----------------------------------------------------------------------------
# IDEs / editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*~

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Local virtual environments. The project assumes the system Python on
# Ubuntu 24.04 + the Isaac Sim conda env (managed by `scripts/isaac_*.sh`).
# Per-developer venvs / conda envs in the workspace stay local.
# -----------------------------------------------------------------------------
.venv/
venv/
env/
.python-version

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Coverage / profiling
# -----------------------------------------------------------------------------
.coverage
htmlcov/
*.lprof

# Demo media — keep these in repo for README rendering
!docs/media/
!docs/media/*.gif
!docs/media/*.mp4
